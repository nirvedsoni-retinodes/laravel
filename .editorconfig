root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,js,jsx,ts,tsx,vue,css,scss,less,html,blade.php}]
indent_style = space
indent_size = 2

[*.{php,py,rb,go,rs}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
